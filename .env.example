# 이 파일을 .env 로 복사해 실제 값을 채운다(.env 는 커밋되지 않음).
# 로컬 스모크 테스트: DOMAIN=:80 (평문 HTTP). 배포: 실제 도메인(자동 HTTPS).

# 도메인 (배포용 예시)
DOMAIN=ttukttakbap.duckdns.org

# DB — mysql 컨테이너 기준. 호스트명은 compose 서비스명 'mysql'.
DB_URL=jdbc:mysql://mysql:3306/ttukttakbap?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
DB_USERNAME=ttukttak
DB_PASSWORD=change-me-strong
MYSQL_DATABASE=ttukttakbap
MYSQL_ROOT_PASSWORD=change-me-root-strong

# JWT — 32바이트 이상 랜덤(예: openssl rand -base64 48)
JWT_SECRET=change-me-please-32bytes-minimum-random-secret

# 카카오 — REST API 키(프론트 authorize + 백엔드 토큰교환 공용). CLIENT_SECRET은 선택.
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=

# 어드민 (HTTP Basic)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong

# 리프레시 토큰 저장 — 재시작 내성 위해 redis 사용
REFRESH_TOKEN_STORE=redis
REDIS_HOST=redis

# CORS — same-origin이라 사실상 불필요하나 안전값으로 도메인 지정
CORS_ALLOWED_ORIGINS=https://ttukttakbap.duckdns.org
